&CONTROL
  calculation  = 'scf'
  prefix       = 'Al'
  outdir       = './tmp'
  pseudo_dir   = './pseudo'
/
&SYSTEM
  ibrav        = 2
  celldm(1)    = 7.652
  nat          = 1
  ntyp         = 1
  ecutwfc      = 30.0
  ecutrho      = 120.0
  occupations  = 'smearing'
  smearing     = 'mv'
  degauss      = 0.02
/
&ELECTRONS
  conv_thr     = 1.0d-10
/
ATOMIC_SPECIES
  Al  26.98  Al.pbe-n-rrkjus_psl.1.0.0.UPF

ATOMIC_POSITIONS {alat}
  Al  0.0  0.0  0.0

K_POINTS {automatic}
  12 12 12  0 0 0
